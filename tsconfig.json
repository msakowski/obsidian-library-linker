{
  "compilerOptions": {
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES6",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "strict": true,
    "lib": ["DOM", "ES5", "ES6", "ES7"],
    "types": ["jest", "node"],
    "esModuleInterop": true,
    "paths": {
      "@/*": ["./src/*"],
      "mocks/*": ["./src/__tests__/__mocks__/*"],
    },
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules/**", "*.js", "*.mjs"],
}
