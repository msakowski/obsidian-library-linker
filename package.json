{
  "name": "jw-library-linker",
  "version": "0.16.2",
  "description": "An Obsidian plugin that helps creating JW Library links",
  "main": "main.js",
  "scripts": {
    "dev": "cross-env DEBUG=true node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "changeset version && node version-bump.mjs",
    "release": "VERSION=$(jq -r '.version' manifest.json) && if git ls-remote --tags origin | grep -q \"refs/tags/$VERSION$\"; then echo \"Tag $VERSION already exists, skipping.\"; else git tag -a $VERSION -m \"Release $VERSION\" && git push origin $VERSION; fi",
    "test:lint": "pnpm test:lint-ts && pnpm test:lint-md",
    "test:lint-fix": "pnpm test:lint-ts-fix && pnpm test:lint-md-fix",
    "test:lint-ts": "eslint",
    "test:lint-ts-fix": "eslint --fix",
    "test:lint-md": "remark . --frail --quiet",
    "test:lint-md-fix": "remark . --output --quiet",
    "test:types": "tsc --noEmit -skipLibCheck",
    "test:jest": "jest",
    "test:jest-watch": "jest --watch",
    "test:jest-affected": "jest --changedSince=origin/main",
    "test": "npm run test:lint-fix && npm run test:types && npm run test:jest",
    "test:affected": "npm run test:lint && npm run test:types && npm run test:jest-affected",
    "changeset": "npx changeset",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged",
    "pre-push": "sh scripts/pre-push.sh"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": "eslint --fix",
    "*.md": "remark --output --quiet --frail --silently-ignore"
  },
  "keywords": [],
  "author": {
    "name": "Martin Sakowski",
    "url": "https://msakowski.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@swc/core": "^1.15.40",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-util": "^30.4.1",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.2",
    "obsidian": "^1.13.0",
    "prettier": "^3.8.3",
    "remark-cli": "^12.0.1",
    "remark-gfm": "^4.0.1",
    "remark-preset-lint-recommended": "^7.0.1",
    "simple-git-hooks": "^2.13.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "yaml": "^2.9.0"
  },
  "packageManager": "pnpm@11.1.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "fflate": "^0.8.3"
  }
}
